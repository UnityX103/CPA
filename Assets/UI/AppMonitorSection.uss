.app-monitor-container {
    width: 100%;
    height: 100%;
    justify-content: center;
    align-items: center;
}

.app-monitor-section {
    flex-direction: row;
    align-items: center;
    padding: 32px;
    border-width: 2px;
    border-radius: 16px;
    background-color: var(--app-monitor-surface-bg);
    border-color: var(--app-monitor-border-color);
    min-width: 600px;
}

.app-icon {
    width: 128px;
    height: 128px;
    min-width: 128px;
    min-height: 128px;
    max-width: 128px;
    max-height: 128px;
    margin-right: 24px;
    border-width: 2px;
    border-radius: 16px;
    border-color: var(--app-monitor-border-color);
    background-color: var(--app-monitor-icon-bg);
    background-repeat: no-repeat;
    background-position: center;
    -unity-background-scale-mode: scale-to-fit;
    flex-shrink: 0;
}

.app-meta {
    flex-direction: column;
    flex-grow: 1;
    min-width: 0;
}

.app-name {
    margin-bottom: 8px;
    font-size: 48px;
    -unity-font-style: bold;
    color: var(--app-monitor-primary-text-color);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.window-title {
    font-size: 32px;
    color: var(--app-monitor-secondary-text-color);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.unity-theme-light .app-monitor-section {
    --app-monitor-surface-bg: var(--unity-colors-help-box-background, transparent);
    --app-monitor-border-color: var(--unity-colors-default-border, transparent);
    --app-monitor-icon-bg: var(--unity-colors-default-background, transparent);
    --app-monitor-primary-text-color: var(--unity-colors-default-text, currentColor);
    --app-monitor-secondary-text-color: var(--unity-colors-default-text, currentColor);
}

.unity-theme-dark .app-monitor-section {
    --app-monitor-surface-bg: var(--unity-colors-default-background, transparent);
    --app-monitor-border-color: var(--unity-colors-default-border, transparent);
    --app-monitor-icon-bg: var(--unity-colors-help-box-background, transparent);
    --app-monitor-primary-text-color: var(--unity-colors-default-text, currentColor);
    --app-monitor-secondary-text-color: var(--unity-colors-default-text, currentColor);
}

.unity-theme-light .window-title {
    opacity: 0.72;
}

.unity-theme-dark .window-title {
    opacity: 0.8;
}
