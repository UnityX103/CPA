/*
 * PetSettingsPanel.uss
 * 对应 Pencil 组件: Pet Settings Panel (id = v2ZgA)
 */

.pet-root {
    width: 572px; /* Pencil: fill_container(572) */
    flex-direction: column;
    border-radius: 20px;
    border-width: 1px;
    border-color: rgb(241, 229, 216); /* #F1E5D8 */
    background-color: rgb(255, 255, 255);
    padding: 20px;
    overflow: hidden;
}

/* Panel Title 样式已迁移至 Components/PanelTitle.uss */
