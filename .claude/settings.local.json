{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__UnityMCP__*",
      "WebFetch(domain:github.com)",
      "mcp__codex__codex",
      "WebFetch(domain:docs.unity3d.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__ide__getDiagnostics",
      "WebSearch",
      "WebFetch(domain:docs.pencil.dev)",
      "WebFetch(domain:pencil.dev)",
      "WebFetch(domain:dev.classmethod.jp)",
      "mcp__pencil__get_editor_state"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm\t*)",
      "Bash(rmdir *)",
      "Bash(* rm *)",
      "Bash(* rm\t*)",
      "Bash(unlink *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "pencil"
  ]
}
