# UOS CDN 凭据模板。
#
# 用法：
#   1) cp cdn/.uas-credentials.env.example cdn/.uas-credentials.env
#   2) 在 https://uos.unity.cn → 内容分发 → 应用密钥 取值后填进 cdn/.uas-credentials.env
#   3) 真的 .uas-credentials.env 已被 .gitignore 屏蔽，不会入库
#
# 变量名必须严格保持 UAS_ 前缀（cdn/uos/_lib.sh、cdn/upload-aa.sh 都按这个读）。
UAS_APP_ID=
UAS_APP_SERVICE_SECRET=
UAS_BUCKET_ID=
# 可选：
# - UAS_BADGE：默认 latest，生产/灰度建议改成版本化 badge（见 SECURITY_TODO.md TODO-SEC-4）
# - UAS_LOAD_URL_PREFIX：默认 https://a.unity.cn/client_api/v1/buckets/${UAS_BUCKET_ID}/release_by_badge/${UAS_BADGE}/content
# - UAS_APP_SECRET：仅诊断脚本兼容旧鉴权路径用，CLI v1.0.9+ 实际只接受 service secret
UAS_BADGE=latest
